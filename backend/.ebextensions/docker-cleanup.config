files:
  "/etc/cron.hourly/docker-cleanup":
    mode: "000755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      THRESHOLD=75
      USAGE=$(df / | awk 'NR==2 {gsub("%",""); print $5}')
      if [ "$USAGE" -gt "$THRESHOLD" ]; then
        echo "[docker-cleanup] Disk usage ${USAGE}% exceeds ${THRESHOLD}%. Pruning Docker..." | logger -t docker-cleanup
        docker system prune -af >> /var/log/docker-cleanup.log 2>&1
        echo "[docker-cleanup] Done. Disk usage now $(df / | awk 'NR==2 {print $5}')." | logger -t docker-cleanup
      fi
